# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/cpim_asamblea"

# Email (SMTP para alertas)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-contraseña-de-aplicacion"
EMAIL_FROM="CPIM Asambleas <tu-email@gmail.com>"

# URL de la aplicación (para Railway: la URL que te asigna)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Directorio de uploads (Railway: montar volumen en /app/uploads)
UPLOAD_DIR="./uploads"
